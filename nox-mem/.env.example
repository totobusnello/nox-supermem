# nox-mem environment configuration
# Copy to .env and fill in required values.
# Source before running: set -a; source .env; set +a
#
# parent: reconcile against agent reports

# ─── Required ─────────────────────────────────────────────────────────────────

# Gemini API key (AI Studio — https://aistudio.google.com/apikey)
# Prepaid quota is per-project, not per-key. Use a key from the active billing project.
GEMINI_API_KEY=

# Path to the SQLite database file (created on first run)
NOX_DB_PATH=/root/.openclaw/workspace/tools/nox-mem/nox-mem.db

# Directory where memory markdown files live (watched for ingest)
NOX_MEM_DIR=/root/.openclaw/workspace/memory

# ─── API server ───────────────────────────────────────────────────────────────

# HTTP API port (default 18802 — do NOT use 18800, Chrome squats it)
NOX_API_PORT=18802

# Bind address (default 127.0.0.1 — do NOT expose to 0.0.0.0 without auth)
NOX_API_HOST=127.0.0.1

# Bearer token for /api/* endpoints (generate with: openssl rand -hex 32)
NOX_API_TOKEN=

# ─── Multi-provider (optional) ────────────────────────────────────────────────
# Default: Gemini via AI Studio. Override to use any OpenAI-compat provider.

# LLM provider for reasoning/consolidation
#NOX_LLM_PROVIDER=openai-compat
#NOX_LLM_BASE_URL=https://openrouter.ai/api/v1
#NOX_LLM_MODEL=deepseek/deepseek-chat
#NOX_LLM_API_KEY=

# Embedding provider
#NOX_EMBED_PROVIDER=openai-compat
#NOX_EMBED_BASE_URL=https://openrouter.ai/api/v1
#NOX_EMBED_MODEL=text-embedding-3-small
#NOX_EMBED_API_KEY=

# ─── Advanced / optional ──────────────────────────────────────────────────────

# Comma-separated absolute path prefixes allowed for op-audit snapshot writes
#NOX_OP_AUDIT_ALLOWED_PREFIXES=/var/backups/nox-mem

# Directory for pre-operation snapshots (default /var/backups/nox-mem/pre-op/)
#NOX_PRE_OP_SNAPSHOT_DIR=/var/backups/nox-mem/pre-op

# Comma-separated entity names that cannot be deleted without --force
#NOX_PROTECTED_NAMES=

# OpenClaw workspace root (used to resolve relative memory paths)
#OPENCLAW_WORKSPACE=/root/.openclaw/workspace
